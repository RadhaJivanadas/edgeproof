# demo: runs immediately with a deterministic synthetic replay
# txline: connects to live TxLINE snapshots/SSE
DATA_MODE=demo
PORT=3000

# Mainnet by default. Devnet: https://txline-dev.txodds.com
TXLINE_BASE_URL=https://txline.txodds.com
# Optional: when omitted, EdgeProof obtains and renews a guest JWT automatically
TXLINE_JWT=
TXLINE_API_TOKEN=
TXLINE_FIXTURE_ID=18209181
HOME_TEAM=France
AWAY_TEAM=Morocco
COMPETITION_NAME=World Cup 2026

# Agent risk controls
STARTING_BANKROLL=10000
MAX_KELLY_FRACTION=0.03
MIN_EDGE=0.035
MIN_CONFIDENCE=0.68
